library(shiny)
library(ggplot2)
library(dplyr)
library(DT)
data("ChickWeight")
pollos <- ChickWeight %>%
mutate(
Diet = factor(Diet),
Chick = factor(Chick),
Time = as.numeric(Time),
weight = as.numeric(weight)
)
#Preparar Los Datos
str(pollos)
head(pollos)
summary(pollos)
ui <- fluidPage(
titlePanel("Explorador de crecimiento de pollitos"),
sidebarLayout(
sidebarPanel(
helpText("Use los controles para filtrar los registros"),
sliderInput("rango_tiempo", "Rango de dias:",
min = min(pollos$Time),
max = max(pollos$Time),
value = range(pollos$Time)),
sliderInput("rango_peso", "Rango de peso:",
min = min(pollos$weight),
max = max(pollos$weight),
value = range(pollos$weight)),
checkboxGroupInput("dietas", "Dietas",
choices = levels(pollos$Diet),
selected = levels(pollos$Diet)),
selectInput("pollos_seleccionados", "Pollitos:",
choices = levels(pollos$Chick),
selected = levels(pollos$Chick),
multiple = TRUE),
radioButtons("tipo_grafico", "Tipo de graficos:",
choices = c("Dispersion", "Cajas", "Lineas promedio")),
checkboxInput("linea_tendencia", "Agregar tendencia lineal",
value = FALSE),
actionButton("resetear", "Restablecer filtros")
),
mainPanel(
textOutput("cantidad"),
textOutput("promedio_peso"),
textOutput("pollitos_unicos"),
plotOutput("grafico_principal"),
DTOutput("tabla_pollos")
)
)
)
